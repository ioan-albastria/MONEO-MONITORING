{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "start",
            "label": "ng serve",
            "detail": "ng serve",
            "runOptions": {
                "instanceLimit": 1
            },
            "problemMatcher": [
                {
                    "owner": "typescript",
                    "source": "ts",
                    "applyTo": "closedDocuments",
                    "fileLocation": ["relative", "${cwd}"],
                    "pattern": "$tsc",
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": { "regexp": "(.*?)" },
                        "endsPattern": { "regexp": "bundle generation complete" }
                    }
                }
            ],
            "isBackground": true
        }
    ]
}
