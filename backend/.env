# Copy of .env.example — fill in real values before running

DATABASE_URL=postgresql://postgres:postgres@localhost/moneo_monitoring
MONEO_API_BASE_URL=https://ifm-ro-sales.w-eu.moneo.ifm/api/platform/v1
MONEO_API_KEY=API+KEY+GOES+HERE
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
REDIS_URL=redis://localhost:6379
SENSOR_POLL_INTERVAL_SECONDS=300
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:3000"]
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
